# EVZONE backend remote-backed development profile
# Used with: ENV_FILE=.env.remote

NODE_ENV=development
PORT=3000
OCPP_PUBLIC_WS_BASE_URL=wss://ocpp.evzonecharging.com

# Database (managed/remote)
DATABASE_URL=postgresql://REPLACE_USER:REPLACE_PASS@REPLACE_HOST:25060/defaultdb?sslmode=require
DATABASE_TLS=true
DATABASE_TLS_REJECT_UNAUTHORIZED=true
# Remote container/server path example:
DATABASE_TLS_CA_PATH=/app/certs/db-ca-chain.pem
# Local path alternative when running on your workstation:
# DATABASE_TLS_CA_PATH=./certs/db-ca-chain.pem

# Redis (managed/remote)
REDIS_HOST=REPLACE_REDIS_HOST
REDIS_PORT=25061
REDIS_URL=rediss://default:REPLACE_REDIS_PASS@REPLACE_REDIS_HOST:25061
REDIS_TLS=true
REDIS_TLS_REJECT_UNAUTHORIZED=true

# Kafka (managed/remote)
KAFKA_BROKERS=REPLACE_KAFKA_HOST:25073
KAFKA_SSL=true
KAFKA_SSL_REJECT_UNAUTHORIZED=true
KAFKA_SSL_CA_PATH=/app/certs/kafka-ca.pem
KAFKA_SASL_MECHANISM=scram-sha-256
KAFKA_SASL_USERNAME=REPLACE_KAFKA_USERNAME
KAFKA_SASL_PASSWORD=REPLACE_KAFKA_PASSWORD
KAFKA_EVENT_CLIENT_ID=evzone-backend-api
KAFKA_EVENT_GROUP_ID=evzone-backend-api-events
KAFKA_EVENTS_ENABLED=false
API_KAFKA_REQUIRED_ON_STARTUP=false
API_READINESS_REQUIRE_KAFKA=false
API_READINESS_REQUIRE_REDIS=false

# CORS
CORS_ORIGINS=https://portal.evzonecharging.com
FRONTEND_URL=https://portal.evzonecharging.com

# Messaging providers (fill with live credentials)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_SENDGRID_API_KEY=
TWILIO_SENDGRID_FROM=EVzone Charging <noreply@evzonecharging.com>
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_FROM=
SUBMAIL_MAIL_APPID=
SUBMAIL_MAIL_APPKEY=
SUBMAIL_MAIL_FROM=EVzone Charging <noreply@evzonecharging.com>
SUBMAIL_SMS_APPID=
SUBMAIL_SMS_APPKEY=

# Auth
JWT_SECRET=change_me_remote_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_SERVICE_SECRET=change_me_service_secret
JWT_SERVICE_ISSUER=evzone-backend
JWT_SERVICE_AUDIENCE=evzone-services
JWT_SERVICE_EXPIRY=1y
