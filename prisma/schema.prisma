generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          String                       @id @default(uuid())
  name                        String
  email                       String?                      @unique
  phone                       String?                      @unique
  passwordHash                String?
  status                      String                       @default("Pending")
  otpCode                     String?
  otpExpiresAt                DateTime?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  role                        UserRole                     @default(SITE_OWNER)
  ownerCapability             StationOwnerCapability?
  country                     String?
  organizationId              String?
  region                      String?
  subscribedPackage           String?
  emailVerifiedAt             DateTime?
  postalCode                  String?
  zoneId                      String?
  providerId                  String?
  mustChangePassword          Boolean                      @default(false)
  lastStationAssignmentId     String?
  twoFactorEnabled            Boolean                      @default(false)
  twoFactorSecret             String?
  mfaRequired                 Boolean                      @default(false) @map("mfa_required")
  attendantAssignmentRequests AttendantAssignmentRequest[]
  attendantAssignments        AttendantAssignment[]
  attendantNotifications      AttendantNotification[]
  bookings                    Booking[]
  createdReceiptTransactions  ChargingReceiptTransaction[]
  uploadedDocuments           Document[]                   @relation("UploadedDocuments")
  verifiedDocuments           Document[]                   @relation("VerifiedDocuments")
  emailVerificationTokens     EmailVerificationToken[]
  fleetDrivers                FleetDriver[]
  invoices                    Invoice[]
  assignedJobs                Job[]                        @relation("TechnicianJobs")
  mfaChallenges               MfaChallenge[]
  mfaRecoveryCodes            MfaRecoveryCode[]
  proposedNegotiations        NegotiationRound[]           @relation("ProposedNegotiations")
  respondedNegotiations       NegotiationRound[]           @relation("RespondedNegotiations")
  memberships                 OrganizationMembership[]
  passkeyCredentials          PasskeyCredential[]
  paymentIntents              PaymentIntent[]
  paymentMethods              PaymentMethod[]
  ownedSites                  Site[]
  payoutProfilesCreated       StaffPayoutProfile[]         @relation("StaffPayoutProfileCreatedBy")
  payoutProfilesUpdated       StaffPayoutProfile[]         @relation("StaffPayoutProfileUpdatedBy")
  staffPayoutProfile          StaffPayoutProfile?
  teamAssignmentsCreated      StationTeamAssignment[]      @relation("StationTeamAssignedBy")
  stationTeamAssignments      StationTeamAssignment[]      @relation("StationTeamAssignmentUser")
  operatedStations            Station[]                    @relation("StationOperator")
  ownedStations               Station[]                    @relation("StationOwner")
  technicianStatus            TechnicianAvailability?
  applications                TenantApplication[]          @relation("Applications")
  reviewedTenantApplications  TenantApplication[]          @relation("ReviewedApplications")
  reviewedUserApplications    UserApplication[]            @relation("ReviewedBy")
  application                 UserApplication?             @relation("UserApplication")
  invitations                 UserInvitation[]
  organization                Organization?                @relation(fields: [organizationId], references: [id])
  provider                    SwapProvider?                @relation(fields: [providerId], references: [id])
  zone                        GeographicZone?              @relation(fields: [zoneId], references: [id])
  vehicles                    Vehicle[]
  wallets                     Wallet?

  @@index([providerId])
  @@map("users")
}

model Organization {
  id                          String                       @id @default(uuid())
  name                        String
  description                 String?
  logoUrl                     String?
  type                        String                       @default("COMPANY")
  paymentProvider             String?
  walletNumber                String?
  taxId                       String?
  regId                       String?
  address                     String?
  city                        String?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  tenantSubdomain             String?                      @unique @map("tenant_subdomain")
  tenantTier                  TenantTier                   @default(SHARED) @map("tenant_tier")
  tenantSchema                String?                      @map("tenant_schema")
  tenantRoutingEnabled        Boolean                      @default(false) @map("tenant_routing_enabled")
  primaryDomain               String?                      @map("primary_domain")
  allowedOrigins              String[]                     @default([]) @map("allowed_origins")
  whiteLabelConfig            Json?                        @map("white_label_config")
  billingPlanCode             String?                      @map("billing_plan_code")
  billingStatus               String?                      @map("billing_status")
  suspendedAt                 DateTime?                    @map("suspended_at")
  developerApiKeys            DeveloperApiKey[]
  developerApiUsage           DeveloperApiUsage[]
  developerApps               DeveloperApp[]
  energyDerProfiles           EnergyDerProfile[]
  enterpriseIdentityProviders EnterpriseIdentityProvider[]
  enterpriseIdentitySyncJobs  EnterpriseIdentitySyncJob[]
  fleetAccounts               FleetAccount[]
  fleetDriverGroups           FleetDriverGroup[]
  fleetDriverTokens           FleetDriverToken[]
  fleetDrivers                FleetDriver[]
  memberships                 OrganizationMembership[]
  paymentIntents              PaymentIntent[]
  paymentMethods              PaymentMethod[]
  pncCertificateEvents        PncCertificateEvent[]
  pncCertificates             PncContractCertificate[]
  pncContracts                PncContract[]
  ownerProviderRelationships  ProviderRelationship[]       @relation("OwnerOrganization")
  sites                       Site[]
  swapProviders               SwapProvider[]               @relation("ProviderOrganization")
  provisionedApplications     TenantApplication[]          @relation("ProvisionedOrganizationApplications")
  brandingRevisions           TenantBrandingRevision[]
  invitations                 UserInvitation[]
  users                       User[]
  vehicles                    Vehicle[]
  wallets                     Wallet[]
  webhooks                    Webhook[]

  @@map("organizations")
}

model TenantBrandingRevision {
  id                    String                       @id @default(uuid())
  organizationId        String                       @map("organization_id")
  version               Int
  status                TenantBrandingRevisionStatus
  config                Json                         @map("config_json")
  publishedAt           DateTime?                    @map("published_at")
  rolledBackFromVersion Int?                         @map("rolled_back_from_version")
  createdBy             String?                      @map("created_by")
  updatedBy             String?                      @map("updated_by")
  createdAt             DateTime                     @default(now()) @map("created_at")
  updatedAt             DateTime                     @updatedAt @map("updated_at")
  organization          Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, version])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("tenant_branding_revisions")
}

model OrganizationMembership {
  id               String                  @id @default(uuid())
  userId           String
  organizationId   String
  role             UserRole
  ownerCapability  StationOwnerCapability?
  status           MembershipStatus        @default(INVITED)
  invitedBy        String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  customRoleId     String?
  customRoleName   String?
  canonicalRoleKey CanonicalRoleKey?
  organization     Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId, status])
  @@index([userId, status])
  @@map("organization_memberships")
}

model UserInvitation {
  id                     String                  @id @default(uuid())
  email                  String
  userId                 String?
  organizationId         String
  role                   UserRole
  ownerCapability        StationOwnerCapability?
  invitedBy              String?
  tokenHash              String                  @unique
  status                 InvitationStatus        @default(PENDING)
  expiresAt              DateTime
  acceptedAt             DateTime?
  activatedAt            DateTime?
  tempPasswordHash       String?
  tempPasswordIssuedAt   DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  initialAssignmentsJson Json?
  customRoleId           String?
  customRoleName         String?
  canonicalRoleKey       CanonicalRoleKey?
  organization           Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                   User?                   @relation(fields: [userId], references: [id])

  @@index([email, organizationId, status])
  @@index([organizationId, status])
  @@index([expiresAt])
  @@map("user_invitations")
}

model SwapProvider {
  id                    String                    @id @default(uuid())
  name                  String
  logoUrl               String?
  legalName             String?
  registrationNumber    String?
  taxId                 String?
  contactEmail          String?
  contactPhone          String?
  region                String
  regions               String[]                  @default([])
  countries             String[]                  @default([])
  organizationId        String?
  standard              String                    @default("Universal")
  batteriesSupported    String[]                  @default([])
  supportedStationTypes String[]                  @default([])
  protocolCapabilities  String[]                  @default([])
  feeModel              String?
  settlementTerms       String?
  stationCount          Int                       @default(0)
  website               String?
  status                SwapProviderStatus        @default(DRAFT)
  statusReason          String?
  approvedAt            DateTime?
  suspendedAt           DateTime?
  requiredDocuments     ProviderDocumentType[]    @default([])
  partnerSince          DateTime                  @default(now())
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  complianceMarkets     String[]                  @default([])
  complianceProfile     Json?
  documents             ProviderDocument[]
  relationships         ProviderRelationship[]
  settlementEntries     ProviderSettlementEntry[]
  organization          Organization?             @relation("ProviderOrganization", fields: [organizationId], references: [id])
  users                 User[]

  @@index([status])
  @@index([region])
  @@index([organizationId])
  @@map("swap_providers")
}

model ProviderRelationship {
  id                  String                     @id @default(uuid())
  providerId          String
  ownerOrgId          String
  status              ProviderRelationshipStatus @default(REQUESTED)
  requestedBy         String?
  providerRespondedAt DateTime?
  adminApprovedAt     DateTime?
  notes               String?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  complianceMarkets   String[]                   @default([])
  complianceProfile   Json?
  documents           ProviderDocument[]
  ownerOrg            Organization               @relation("OwnerOrganization", fields: [ownerOrgId], references: [id])
  provider            SwapProvider               @relation(fields: [providerId], references: [id], onDelete: Cascade)
  settlementEntries   ProviderSettlementEntry[]

  @@index([providerId])
  @@index([ownerOrgId])
  @@index([status])
  @@map("provider_relationships")
}

model ProviderDocument {
  id                 String                 @id @default(uuid())
  providerId         String?
  relationshipId     String?
  ownerOrgId         String?
  type               ProviderDocumentType
  name               String
  fileUrl            String
  uploadedAt         DateTime               @default(now())
  uploadedBy         String?
  status             ProviderDocumentStatus @default(PENDING)
  rejectionReason    String?
  requirementCode    String?
  category           String?
  issuer             String?
  documentNumber     String?
  issueDate          DateTime?
  expiryDate         DateTime?
  coveredModels      String[]               @default([])
  coveredSites       String[]               @default([])
  version            String?
  metadata           Json?
  reviewedBy         String?
  reviewedAt         DateTime?
  reviewNotes        String?
  cloudinaryPublicId String?
  provider           SwapProvider?          @relation(fields: [providerId], references: [id])
  relationship       ProviderRelationship?  @relation(fields: [relationshipId], references: [id])

  @@index([providerId])
  @@index([relationshipId])
  @@index([requirementCode])
  @@index([expiryDate])
  @@index([status])
  @@map("provider_documents")
}

model BatteryPack {
  id                String              @id @default(uuid())
  serialNumber      String              @unique
  status            BatteryPackStatus   @default(READY)
  bmsType           String              @default("UNKNOWN_3RD_PARTY")
  capacityAh        Float               @default(0)
  soc               Float?
  soh               Float?
  voltage           Float?
  current           Float?
  temperature       Float?
  cycleCount        Int                 @default(0)
  healthScore       Float?
  firmwareVersion   String?
  providerId        String?
  stationId         String?
  cabinetId         String?
  slotId            String?
  orgId             String?
  tenantId          String?
  lastTelemetryAt   DateTime?
  quarantinedAt     DateTime?
  retiredAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  telemetry         BatteryTelemetry[]
  slot              BatteryCabinetSlot? @relation("PackSlot")

  @@index([serialNumber])
  @@index([status])
  @@index([providerId])
  @@index([stationId])
  @@index([orgId])
  @@index([tenantId])
  @@map("battery_packs")
}

model BatteryTelemetry {
  id            String      @id @default(uuid())
  packId        String
  source        String      @default("MQTT_BMS")
  voltage       Float?
  current       Float?
  soc           Float?
  soh           Float?
  temps         Float[]     @default([])
  cells         Float[]     @default([])
  cellVoltages  Json?
  alerts        Json?
  rawPayload    Json?
  timestamp     DateTime    @default(now())
  ingestedAt    DateTime    @default(now())
  createdAt     DateTime    @default(now())
  pack          BatteryPack @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@index([packId])
  @@index([timestamp])
  @@index([source])
  @@map("battery_telemetry")
}

model BatteryCabinet {
  id              String               @id @default(uuid())
  cabinetId       String   @unique
  stationId       String
  providerId      String
  tenantId        String
  orgId           String?
  status          BatteryCabinetStatus @default(ONLINE)
  isOnline        Boolean              @default(true)
  powerState      String               @default("OK")
  doorLocked      Boolean              @default(true)
  robotHealth     String               @default("OK")
  totalSlots      Int                  @default(0)
  occupiedSlots   Int                  @default(0)
  faultCodes      String[]             @default([])
  lastHeartbeatAt DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  slots           BatteryCabinetSlot[]

  @@index([cabinetId])
  @@index([stationId])
  @@index([providerId])
  @@index([tenantId])
  @@index([status])
  @@map("battery_cabinets")
}

model BatteryCabinetSlot {
  id          String         @id @default(uuid())
  cabinetId   String
  slotNumber  Int
  status      String         @default("EMPTY")
  packId      String?        @unique
  isEnabled   Boolean        @default(true)
  faultReason String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  cabinet     BatteryCabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  pack        BatteryPack?   @relation(name: "PackSlot", fields: [packId], references: [id])

  @@unique([cabinetId, slotNumber])
  @@index([cabinetId])
  @@index([packId])
  @@map("battery_cabinet_slots")
}

model SwapSession {
  id                   String           @id @default(uuid())
  sessionId            String   @unique
  stationId            String
  cabinetId            String?
  providerId           String
  tenantId             String
  orgId                String?
  vehicleId            String?
  riderId              String?
  inboundPackId        String?
  outboundPackId       String?
  stage                SwapSessionStage @default(INITIATED)
  startedAt            DateTime         @default(now())
  completedAt          DateTime?
  durationSec          Int?
  failureReason        String?
  attendantId          String?
  paymentStatus        String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([sessionId])
  @@index([stationId])
  @@index([providerId])
  @@index([tenantId])
  @@index([stage])
  @@index([startedAt])
  @@map("swap_sessions")
}

model MqttDeviceRegistry {
  id               String   @id @default(uuid())
  vendorDeviceId   String   @unique
  integrationType  String?
  deviceType       String?
  tenantId         String
  siteId           String?
  stationId        String?
  providerId       String?
  vendorProviderId String?
  capabilities     Json?
  metadata         Json?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  site             Site?    @relation(fields: [siteId], references: [id])

  @@index([vendorDeviceId])
  @@index([siteId])
  @@index([stationId])
  @@index([tenantId])
  @@index([isActive])
  @@map("mqtt_device_registries")
}

model MqttVendorPayloadLog {
  id                  String   @id @default(uuid())
  tenantId            String
  vendorDeviceId      String?
  deviceRegistryId    String?
  topic               String
  payload             Json
  normalizedEventType String?
  errorMessage        String?
  processedAt         DateTime?
  createdAt           DateTime @default(now())

  @@index([tenantId])
  @@index([vendorDeviceId])
  @@index([normalizedEventType])
  @@index([createdAt])
  @@map("mqtt_vendor_payload_logs")
}

model BatteryProviderAssignment {
  id                 String                          @id @default(uuid())
  tenantId           String
  providerId         String
  assignedStationIds String[]                        @default([])
  assignedCabinetIds String[]                        @default([])
  status             BatteryProviderAssignmentStatus @default(PENDING)
  contractType       String?
  startedAt          DateTime                        @default(now())
  endedAt            DateTime?
  createdAt          DateTime                        @default(now())
  updatedAt          DateTime                        @updatedAt

  @@index([tenantId])
  @@index([providerId])
  @@index([status])
  @@map("battery_provider_assignments")
}

model BatteryProviderUserScope {
  id                 String                   @id @default(uuid())
  userId             String
  tenantId           String
  providerId         String
  role               BatteryProviderUserRole  @default(VIEWER)
  assignedStationIds String[]                 @default([])
  assignedCabinetIds String[]                 @default([])
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([userId])
  @@index([tenantId])
  @@index([providerId])
  @@unique([userId, tenantId, providerId])
  @@map("battery_provider_user_scopes")
}

model BatteryProviderSlaSnapshot {
  id                    String   @id @default(uuid())
  tenantId              String
  providerId            String
  periodStart           DateTime
  periodEnd             DateTime
  providerUptimePct     Float    @default(0)
  cabinetUptimePct      Float    @default(0)
  telemetryFreshnessPct Float    @default(0)
  packAvailabilityPct   Float    @default(0)
  failedSwapRatePct     Float    @default(0)
  avgResolutionMinutes  Float    @default(0)
  slaBreaches           Int      @default(0)
  createdAt             DateTime @default(now())

  @@unique([tenantId, providerId, periodStart])
  @@index([tenantId, providerId])
  @@index([periodStart, periodEnd])
  @@map("battery_provider_sla_snapshots")
}

model BatteryProviderAlert {
  id               String                       @id @default(uuid())
  tenantId         String
  providerId       String
  category         BatteryProviderAlertCategory
  severity         BatteryProviderAlertSeverity
  status           BatteryProviderAlertStatus   @default(OPEN)
  assetType        String
  assetId          String
  message          String
  firstSeenAt      DateTime                     @default(now())
  lastSeenAt       DateTime                     @default(now())
  assignedToUserId String?
  acknowledgedBy   String?
  acknowledgedAt   DateTime?
  resolvedBy       String?
  resolvedAt       DateTime?
  escalatedToOrgId String?
  metadata         Json?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  @@index([tenantId, providerId])
  @@index([status])
  @@index([severity])
  @@index([category])
  @@index([assetId])
  @@index([createdAt])
  @@map("battery_provider_alerts")
}

model CompliancePolicy {
  id        String   @id @default(uuid())
  code      String   @unique
  data      Json
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("compliance_policies")
}

model ProviderSettlementEntry {
  id             String                   @id @default(uuid())
  relationshipId String?
  providerId     String
  ownerOrgId     String?
  stationId      String?
  sessionId      String?
  amount         Float
  providerFee    Float
  platformFee    Float
  adjustment     Float                    @default(0)
  net            Float
  currency       String                   @default("USD")
  status         ProviderSettlementStatus @default(PENDING)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  provider       SwapProvider             @relation(fields: [providerId], references: [id], onDelete: Cascade)
  relationship   ProviderRelationship?    @relation(fields: [relationshipId], references: [id])

  @@index([providerId])
  @@index([ownerOrgId])
  @@index([createdAt])
  @@index([status])
  @@map("provider_settlement_entries")
}

model MarketplaceContactEvent {
  id           String                       @id @default(uuid())
  actorId      String
  entityKind   MarketplaceContactEntityKind
  entityId     String
  eventType    MarketplaceContactEventType
  entityName   String?
  entityCity   String?
  entityRegion String?
  metadata     Json?
  createdAt    DateTime                     @default(now())

  @@index([actorId, createdAt])
  @@index([actorId, entityKind, entityId, createdAt])
  @@map("marketplace_contact_events")
}

model UserApplication {
  id                String    @id @default(uuid())
  userId            String    @unique
  companyName       String?
  taxId             String?
  country           String
  region            String
  accountType       String    @default("COMPANY")
  role              String
  subscribedPackage String?
  documents         Json?     @default("[]")
  status            String    @default("PENDING")
  reviewedBy        String?
  reviewedAt        DateTime?
  rejectionReason   String?
  adminNotes        String?
  submittedAt       DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  reviewer          User?     @relation("ReviewedBy", fields: [reviewedBy], references: [id])
  user              User      @relation("UserApplication", fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_applications")
}

model SubscriptionPlan {
  id           String           @id @default(uuid())
  name         String
  code         String           @unique
  description  String?
  role         UserRole
  price        Float            @default(0)
  currency     String           @default("USD")
  billingCycle String           @default("MONTHLY")
  isActive     Boolean          @default(true)
  isPublic     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  isPopular    Boolean          @default(false)
  features     PlanFeature[]
  permissions  PlanPermission[]

  @@map("subscription_plans")
}

model PlanFeature {
  id           String           @id @default(uuid())
  planId       String
  featureKey   String
  featureValue String
  description  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  order        Int              @default(0)
  plan         SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("plan_features")
}

model PlanPermission {
  id          String           @id @default(uuid())
  planId      String
  resource    String
  action      String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  plan        SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("plan_permissions")
}

model PermissionDefinition {
  id                            String                         @id @default(uuid())
  code                          String                         @unique
  label                         String
  description                   String?
  scope                         PermissionScope
  resource                      String?
  action                        String?
  isSystem                      Boolean                        @default(true)
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @updatedAt
  systemRoleTemplatePermissions SystemRoleTemplatePermission[]

  @@index([scope])
  @@map("permission_definitions")
}

model SystemRoleTemplate {
  id             String                         @id @default(uuid())
  key            CanonicalRoleKey               @unique
  label          String
  description    String?
  family         String
  scope          PermissionScope
  isPlatformRole Boolean                        @default(false)
  customizable   Boolean                        @default(false)
  version        Int                            @default(1)
  createdAt      DateTime                       @default(now())
  updatedAt      DateTime                       @updatedAt
  permissions    SystemRoleTemplatePermission[]

  @@map("system_role_templates")
}

model SystemRoleTemplatePermission {
  id             String               @id @default(uuid())
  roleTemplateId String
  permissionId   String
  createdAt      DateTime             @default(now())
  permission     PermissionDefinition @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  roleTemplate   SystemRoleTemplate   @relation(fields: [roleTemplateId], references: [id], onDelete: Cascade)

  @@unique([roleTemplateId, permissionId], map: "system_role_template_permissions_roleTemplateId_permissionId_ke")
  @@index([permissionId])
  @@map("system_role_template_permissions")
}

model PlatformRoleAssignment {
  id         String           @id @default(uuid())
  userId     String
  roleKey    CanonicalRoleKey
  status     MembershipStatus @default(ACTIVE)
  assignedBy String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([userId, roleKey])
  @@index([userId, status])
  @@map("platform_role_assignments")
}

model Station {
  id                          String                       @id @default(uuid())
  name                        String
  status                      String                       @default("ACTIVE")
  latitude                    Float
  longitude                   Float
  address                     String
  siteId                      String?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  operatorId                  String?
  ownerId                     String?
  type                        StationType                  @default(CHARGING)
  postalCode                  String?
  zoneId                      String?
  orgId                       String?
  rating                      Float                        @default(0)
  price                       Float                        @default(0)
  amenities                   String                       @default("[]")
  images                      String                       @default("[]")
  open247                     Boolean                      @default(false)
  phone                       String?
  bookingFee                  Float                        @default(0)
  attendantAssignmentRequests AttendantAssignmentRequest[]
  attendantAssignments        AttendantAssignment[]
  bookings                    Booking[]
  chargePoints                ChargePoint[]
  energyDerProfiles           EnergyDerProfile[]
  incidents                   Incident[]
  jobs                        Job[]
  stationTeamAssignments      StationTeamAssignment[]
  operator                    User?                        @relation("StationOperator", fields: [operatorId], references: [id])
  owner                       User?                        @relation("StationOwner", fields: [ownerId], references: [id])
