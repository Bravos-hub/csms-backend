  metadata          Json?
  createdAt         DateTime                    @default(now()) @map("created_at")
  updatedAt         DateTime                    @updatedAt @map("updated_at")
  vehicle           Vehicle                     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, status, lastSeenAt], map: "vehicle_faults_vehicle_status_last_seen_at_idx")
  @@index([code, status])
  @@map("vehicle_faults")
}

model TelemetryIngestAlert {
  id                String                   @id @default(uuid())
  type              TelemetryIngestAlertType
  provider          TelemetryProviderType
  providerVehicleId String?                  @map("provider_vehicle_id")
  vehicleId         String                   @map("vehicle_id")
  observedAt        DateTime                 @default(now()) @map("observed_at")
  lagMs             Int?                     @map("lag_ms")
  message           String
  metadata          Json?
  createdAt         DateTime                 @default(now()) @map("created_at")
  vehicle           Vehicle                  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([type, observedAt])
  @@index([vehicleId, observedAt], map: "telemetry_ingest_alerts_vehicle_observed_at_idx")
  @@index([provider, observedAt])
  @@map("telemetry_ingest_alerts")
}

