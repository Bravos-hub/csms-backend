  // Relations to operational entities
  stations  Station[] // Relation to Station
  sites     Site[]    // Relation to Site
  users     User[]    // Relation to User (for Address/Billing)
  
  // Metadata for Operations
  currency        String?  // e.g. "USD" for countries
  timezone        String?  // e.g. "America/New_York"
  postalCodeRegex String? // Regex to validate postal codes for this zone (Country level)
  
