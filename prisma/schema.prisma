  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization      Organization?         @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  fleetAccount      FleetAccount?         @relation(fields: [fleetAccountId], references: [id], onDelete: SetNull)
  fleetDriver       FleetDriver?          @relation(fields: [fleetDriverId], references: [id], onDelete: SetNull)
  fleetDriverGroup  FleetDriverGroup?     @relation(fields: [fleetDriverGroupId], references: [id], onDelete: SetNull)
  depotSite         Site?                 @relation(fields: [depotSiteId], references: [id], onDelete: SetNull)
  sessions          Session[]
  batteryPacks      BatteryPack[]
  telemetrySources  VehicleTelemetrySource[]
  telemetrySnapshots VehicleTelemetrySnapshot[]
  telemetryLatest   VehicleTelemetryLatest?
  faults            VehicleFault[]
  commands          Command[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vehicles")
  @@index([userId])
  @@index([userId, isActive])
  @@index([organizationId], map: "vehicles_organization_id_idx")
  @@index([fleetAccountId], map: "vehicles_fleet_account_id_idx")
  @@index([fleetDriverId], map: "vehicles_fleet_driver_id_idx")
  @@index([fleetDriverGroupId], map: "vehicles_fleet_driver_group_id_idx")
  @@index([depotSiteId], map: "vehicles_depot_site_id_idx")
  @@index([ownershipType, vehicleStatus], map: "vehicles_ownership_status_idx")
  @@index([licensePlate])
}

model VehicleTelemetrySource {
  id                String                    @id @default(uuid())
  vehicleId         String                    @map("vehicle_id")
  provider          TelemetryProviderType
  providerVehicleId String?                   @map("provider_vehicle_id")
  capabilities      VehicleTelemetryCapability[] @default([])
  credentialRef     String?                   @map("credential_ref")
  enabled           Boolean                   @default(true)
  health            VehicleTelemetryHealth    @default(UNKNOWN)
  lastSyncedAt      DateTime?                 @map("last_synced_at")
  metadata          Json?
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("vehicle_telemetry_sources")
  @@unique([vehicleId, provider, providerVehicleId], map: "vehicle_tel_srcs_vehicle_provider_pvid_key")
  @@index([vehicleId, enabled], map: "vehicle_telemetry_sources_vehicle_enabled_idx")
  @@index([provider, health], map: "vehicle_telemetry_sources_provider_health_idx")
}

model VehicleTelemetrySnapshot {
  id                String                @id @default(uuid())
  vehicleId         String                @map("vehicle_id")
  provider          TelemetryProviderType
  providerVehicleId String?               @map("provider_vehicle_id")
  collectedAt       DateTime              @default(now()) @map("collected_at")
  lastSyncedAt      DateTime?             @map("last_synced_at")
  battery           Json?
  gps               Json?
  odometer          Json?
  charging          Json?
  faults            Json?
  sources           Json?
  rawPayload        Json?                 @map("raw_payload")
  createdAt         DateTime              @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("vehicle_telemetry_snapshots")
  @@index([vehicleId, collectedAt], map: "vehicle_telemetry_snapshots_vehicle_collected_at_idx")
  @@index([provider, collectedAt], map: "vehicle_telemetry_snapshots_provider_collected_at_idx")
}

model VehicleTelemetryLatest {
  vehicleId         String                @id @map("vehicle_id")
  provider          TelemetryProviderType
  providerVehicleId String?               @map("provider_vehicle_id")
  lastSyncedAt      DateTime?             @map("last_synced_at")
  sampledAt         DateTime              @default(now()) @map("sampled_at")
  battery           Json?
  gps               Json?
  odometer          Json?
  charging          Json?
  faults            Json?
  sources           Json?
  updatedAt         DateTime              @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("vehicle_telemetry_latest")
  @@index([provider, updatedAt], map: "vehicle_telemetry_latest_provider_updated_at_idx")
}

model VehicleFault {
  id                String                     @id @default(uuid())
  vehicleId         String                     @map("vehicle_id")
  provider          TelemetryProviderType?
  source            String?
  code              String
  severity          VehicleFaultSeverity       @default(WARNING)
  description       String
  status            VehicleFaultLifecycleStatus @default(OPEN)
  recommendedAction String?                    @map("recommended_action")
  firstSeenAt       DateTime                   @default(now()) @map("first_seen_at")
  lastSeenAt        DateTime                   @default(now()) @map("last_seen_at")
  acknowledgedAt    DateTime?                  @map("acknowledged_at")
  acknowledgedBy    String?                    @map("acknowledged_by")
  resolvedAt        DateTime?                  @map("resolved_at")
  resolvedBy        String?                    @map("resolved_by")
  metadata          Json?
  createdAt         DateTime                   @default(now()) @map("created_at")
  updatedAt         DateTime                   @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("vehicle_faults")
  @@index([vehicleId, status, lastSeenAt], map: "vehicle_faults_vehicle_status_last_seen_at_idx")
  @@index([code, status], map: "vehicle_faults_code_status_idx")
}

model BatteryPack {
  id                String            @id @default(uuid())
  serialNumber      String            @unique
  bmsType           String            // e.g., "DALY_16S", "JBD_14S"
  status            BatteryStatus     @default(READY)
  soc               Float             @default(0)
  soh               Float             @default(0)
  cycleCount        Int               @default(0)
  voltage           Float             @default(0)
  current           Float             @default(0)
  capacityAh        Float             @default(0)
  
  stationId         String?
  lockerBayId       String?
  vehicleId         String?

  // Relations
  telemetry         BatteryTelemetry[]
  vehicle           Vehicle?          @relation(fields: [vehicleId], references: [id])
  station           Station?          @relation(fields: [stationId], references: [id])
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@map("battery_packs")
  @@index([stationId])
  @@index([vehicleId])
  @@index([status])
}

model BatteryTelemetry {
  id              String      @id @default(uuid())
  packId          String
  pack            BatteryPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  
  voltage         Float       // Pack voltage
  current         Float       // Charge/Discharge current
  soc             Float
  soh             Float?
  temps           Json        // Array/Object of temperature readings [temp1, temp2]
  cells           Json        // Array of individual cell voltages [3.21, 3.22, ...]
  alerts          Json?       // Active BMS alerts/faults
  
  timestamp       DateTime    @default(now())

  @@index([packId, timestamp])
  @@map("battery_telemetry")
}

enum BatteryStatus {
  READY
  CHARGING
  LOCKED_REMOTE    // The "Remote Kill" state
  FAULTED
  RETIRED
  IN_TRANSIT
  UNKNOWN
}



