  amenities       String      @default("[]") // JSON array
  tags            String      @default("[]") // JSON array of photo URLs
  ownerId         String
  organizationId  String?
  postalCode      String?
  zoneId          String?
  
  // Relations
  zone               GeographicZone?      @relation(fields: [zoneId], references: [id])

  // Relations
  owner              User                 @relation(fields: [ownerId], references: [id])
