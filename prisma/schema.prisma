generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  EVZONE_ADMIN
  EVZONE_OPERATOR
  SWAP_PROVIDER_ADMIN
  SWAP_PROVIDER_OPERATOR
  SITE_OWNER
  STATION_OWNER
  OWNER
  STATION_OPERATOR
  STATION_ADMIN
  MANAGER
  ATTENDANT
  CASHIER
  TECHNICIAN_ORG
  TECHNICIAN_PUBLIC
  DRIVER
}

enum CanonicalRoleKey {
  PLATFORM_SUPER_ADMIN
  PLATFORM_BILLING_ADMIN
  PLATFORM_NOC_LEAD
  TENANT_ADMIN
  STATION_MANAGER
  SITE_HOST
  ROAMING_MANAGER
  FLEET_DISPATCHER
  FLEET_DRIVER
  INSTALLER_AGENT
  SMART_CHARGING_ENGINEER
  OPERATIONS_OPERATOR
  FIELD_TECHNICIAN
  TENANT_FINANCE_ANALYST
  EXTERNAL_PROVIDER_OPERATOR
}

enum PermissionScope {
  PLATFORM
  TENANT
}

enum CustomRoleStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum StationType {
  CHARGING
  SWAPPING
}

enum StationOwnerCapability {
  CHARGE
  SWAP
  BOTH
}

enum SwapProviderStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum ProviderRelationshipStatus {
  REQUESTED
  PROVIDER_ACCEPTED
  DOCS_PENDING
  ADMIN_APPROVED
  ACTIVE
  SUSPENDED
  TERMINATED
}

enum ProviderDocumentType {
  INCORPORATION
  TAX_COMPLIANCE
  INSURANCE
  BATTERY_SAFETY_CERTIFICATION
  RECYCLING_COMPLIANCE
  TECHNICAL_CONFORMANCE
  COMMERCIAL_AGREEMENT
  SOP_ACKNOWLEDGEMENT
  SITE_COMPATIBILITY_DECLARATION
}

enum ProviderDocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProviderSettlementStatus {
  PENDING
  PAID
  DISPUTED
}

enum MqttIntegrationType {
  BATTERY_SWAP
  LEGACY_EVSE
  SITE_CONTROLLER
  BMS
}

enum MqttVendorType {
  NAE_BATTERY
  CHARGEPOINT
  ABB
  WALLBOX
  RIPPLE
  CUSTOM
}

enum MarketplaceContactEntityKind {
  SITE
  OPERATOR
  TECHNICIAN
  PROVIDER
}

enum MarketplaceContactEventType {
  EMAIL
  CALL
  APPLY_SITE
  REQUEST_PARTNERSHIP
}

enum AttendantRoleMode {
  FIXED
  MOBILE
}

enum PayoutMethod {
  MOBILE_MONEY
  BANK_TRANSFER
  CASH_PICKUP
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REVOKED
}

enum EnergyControlMode {
  OBSERVE_ONLY
  ACTIVE
  DISABLED
}

enum EnergyAllocationMethod {
  EQUAL
  PRIORITY
}

enum EnergyMeterPlacement {
  MAIN
  SUB_FEEDER
  DERIVED
}

enum EnergyAlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum EnergyAlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum EnergyDecisionState {
  APPLIED
  DRY_RUN
  NO_CHANGE
  BLOCKED
  FAILED
}

enum EnergyOverrideStatus {
  ACTIVE
  CLEARED
  EXPIRED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  ACTIVATED
  EXPIRED
  REVOKED
}

enum TenantTier {
  SHARED
  SCHEMA
  DEDICATED_DB
}

enum TenantAccountType {
  INDIVIDUAL
  COMPANY
  STATE
  ORGANIZATION
}

enum CpoServiceType {
  CHARGE
  SWAP
  HYBRID
}

enum TenantOnboardingStage {
  SUBMITTED
  UNDER_REVIEW
  APPROVED_PENDING_TIER
  REJECTED
  TIER_CONFIRMED_PENDING_PAYMENT
  QUOTE_PENDING
  PAYMENT_CONFIRMED_PENDING_ACTIVATION
  QUOTE_ACCEPTED_PENDING_ACTIVATION
  COMPLETED
}

enum TenantBrandingRevisionStatus {
  DRAFT
  PUBLISHED
  ROLLED_BACK
}

model User {
  id              String  @id @default(uuid())
  name            String
  email           String? @unique
  phone           String? @unique
  passwordHash    String?
  role            UserRole                @default(SITE_OWNER)
  status          String                  @default("Pending")
  ownerCapability StationOwnerCapability? // Only for STATION_OWNER
  twoFactorSecret String?
  twoFactorEnabled Boolean @default(false)
  mfaRequired Boolean @default(false) @map("mfa_required")
  mustChangePassword Boolean @default(false)
  otpCode         String?
  otpExpiresAt    DateTime?
  emailVerifiedAt DateTime?

  // Registration & Onboarding Fields
  country           String?
  region            String? // Legacy field, eventually replace with zone logic
  postalCode        String?
  zoneId            String?
  subscribedPackage String? // Free, Starter, Growth, Pro, Enterprise
  organizationId    String?
  providerId        String?
  lastStationAssignmentId String?

  // Relations
  zone                 GeographicZone?     @relation(fields: [zoneId], references: [id])

  // Relations
  organization         Organization?       @relation(fields: [organizationId], references: [id])
  provider             SwapProvider?       @relation(fields: [providerId], references: [id])
  memberships          OrganizationMembership[]
  invitations          UserInvitation[]
  applications         TenantApplication[] @relation("Applications")
  ownedStations    Station[] @relation("StationOwner")
  operatedStations Station[] @relation("StationOperator")

  // Document Relations
  uploadedDocuments  Document[] @relation("UploadedDocuments")
  verifiedDocuments  Document[] @relation("VerifiedDocuments")
  
  // Negotiation Relations
  proposedNegotiations  NegotiationRound[] @relation("ProposedNegotiations")
  respondedNegotiations NegotiationRound[] @relation("RespondedNegotiations")

  // Technician Status
  technicianStatus TechnicianAvailability?
  assignedJobs     Job[] @relation("TechnicianJobs")
  attendantAssignments        AttendantAssignment[]
  attendantAssignmentRequests AttendantAssignmentRequest[]
  attendantNotifications      AttendantNotification[]
  stationTeamAssignments      StationTeamAssignment[] @relation("StationTeamAssignmentUser")
  teamAssignmentsCreated      StationTeamAssignment[] @relation("StationTeamAssignedBy")
  staffPayoutProfile          StaffPayoutProfile?
  payoutProfilesCreated       StaffPayoutProfile[] @relation("StaffPayoutProfileCreatedBy")
  payoutProfilesUpdated       StaffPayoutProfile[] @relation("StaffPayoutProfileUpdatedBy")
  createdReceiptTransactions  ChargingReceiptTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Application for Admin Approval
  application               UserApplication?    @relation("UserApplication")
  reviewedUserApplications  UserApplication[]   @relation("ReviewedBy")

  bookings                   Booking[]
  fleetDrivers               FleetDriver[]
  wallets                    Wallet[]
  invoices                   Invoice[]
  paymentMethods             PaymentMethod[]
  paymentIntents             PaymentIntent[]
  ownedSites                 Site[]
  reviewedTenantApplications TenantApplication[] @relation("ReviewedApplications")
  emailVerificationTokens    EmailVerificationToken[]
  passkeyCredentials         PasskeyCredential[]
  mfaChallenges              MfaChallenge[]
  mfaRecoveryCodes           MfaRecoveryCode[]
  vehicles                   Vehicle[]

  sessions                   Session[]
  @@map("users")
  @@index([providerId])
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  description String?
  logoUrl     String?
  type                 String     @default("COMPANY") // COMPANY, INDIVIDUAL
  tenantSubdomain      String?    @unique @map("tenant_subdomain")
  tenantTier           TenantTier @default(SHARED) @map("tenant_tier")
  tenantSchema         String?    @map("tenant_schema")
  tenantRoutingEnabled Boolean    @default(false) @map("tenant_routing_enabled")
  primaryDomain        String?    @map("primary_domain")
  allowedOrigins       String[]   @default([]) @map("allowed_origins")
  whiteLabelConfig     Json?      @map("white_label_config")
  billingPlanCode      String?    @map("billing_plan_code")
  billingStatus        String?    @map("billing_status")
  suspendedAt          DateTime?  @map("suspended_at")
  
  // Financials
  paymentProvider String?  // MTN, AIRTEL, M-PESA
  walletNumber    String?
  taxId           String?
  regId           String?
  
  // Address
  address         String?
  city            String?
  
  users       User[]
  memberships OrganizationMembership[]
  invitations UserInvitation[]
  sites       Site[]
  fleetAccounts FleetAccount[]
  fleetDriverGroups FleetDriverGroup[]
  fleetDrivers FleetDriver[]
  fleetDriverTokens FleetDriverToken[]
  vehicles    Vehicle[]
  webhooks    Webhook[]
  pncContracts PncContract[]
  pncCertificates PncContractCertificate[]
  pncCertificateEvents PncCertificateEvent[]
  enterpriseIdentityProviders EnterpriseIdentityProvider[]
  enterpriseIdentitySyncJobs EnterpriseIdentitySyncJob[]
  developerApps DeveloperApp[]
  developerApiKeys DeveloperApiKey[]
  developerApiUsage DeveloperApiUsage[]
  energyDerProfiles EnergyDerProfile[]
  wallets     Wallet[]
  paymentMethods PaymentMethod[]
  paymentIntents PaymentIntent[]
  provisionedApplications TenantApplication[] @relation("ProvisionedOrganizationApplications")
  swapProviders SwapProvider[] @relation("ProviderOrganization")
  ownerProviderRelationships ProviderRelationship[] @relation("OwnerOrganization")
  brandingRevisions TenantBrandingRevision[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("organizations")
}

model TenantBrandingRevision {
  id                    String                       @id @default(uuid())
  organizationId        String                       @map("organization_id")
  version               Int
  status                TenantBrandingRevisionStatus
  config                Json                         @map("config_json")
  publishedAt           DateTime?                    @map("published_at")
  rolledBackFromVersion Int?                         @map("rolled_back_from_version")
  createdBy             String?                      @map("created_by")
  updatedBy             String?                      @map("updated_by")
  createdAt             DateTime                     @default(now()) @map("created_at")
  updatedAt             DateTime                     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("tenant_branding_revisions")
  @@unique([organizationId, version])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

model OrganizationMembership {
  id              String                 @id @default(uuid())
  userId          String
  organizationId  String
  role            UserRole
  canonicalRoleKey CanonicalRoleKey?
  customRoleId    String?
  customRoleName  String?
  ownerCapability StationOwnerCapability?
  status          MembershipStatus       @default(INVITED)
  invitedBy       String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_memberships")
  @@unique([userId, organizationId])
  @@index([organizationId, status])
  @@index([userId, status])
}

model UserInvitation {
  id                  String                 @id @default(uuid())
  email               String
  userId              String?
  organizationId      String
  role                UserRole
  canonicalRoleKey    CanonicalRoleKey?
  customRoleId        String?
  customRoleName      String?
  ownerCapability     StationOwnerCapability?
  invitedBy           String?
  tokenHash           String                 @unique
  status              InvitationStatus       @default(PENDING)
  expiresAt           DateTime
  acceptedAt          DateTime?
  activatedAt         DateTime?
  tempPasswordHash    String?
  tempPasswordIssuedAt DateTime?
  initialAssignmentsJson Json?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("user_invitations")
  @@index([email, organizationId, status])
  @@index([organizationId, status])
  @@index([expiresAt])
}

model SwapProvider {
  id                    String               @id @default(uuid())
  name                  String
  logoUrl               String?
  legalName             String?
  registrationNumber    String?
  taxId                 String?
  contactEmail          String?
  contactPhone          String?
  region                String
  regions               String[]             @default([])
  countries             String[]             @default([])
  organizationId        String?
  standard              String               @default("Universal")
  batteriesSupported    String[]             @default([])
  supportedStationTypes String[]             @default([])
  protocolCapabilities  String[]             @default([])
  feeModel              String?
  settlementTerms       String?
  stationCount          Int                  @default(0)
  website               String?
  status                SwapProviderStatus   @default(DRAFT)
  statusReason          String?
  approvedAt            DateTime?
  suspendedAt           DateTime?
  requiredDocuments     ProviderDocumentType[] @default([])
  complianceMarkets     String[]             @default([])
  complianceProfile     Json?
  partnerSince          DateTime             @default(now())
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  organization    Organization?             @relation("ProviderOrganization", fields: [organizationId], references: [id])
  users           User[]
  relationships   ProviderRelationship[]
  documents       ProviderDocument[]
  settlementEntries ProviderSettlementEntry[]

  @@map("swap_providers")
  @@index([status])
  @@index([region])
  @@index([organizationId])
}

model ProviderRelationship {
  id                 String                     @id @default(uuid())
  providerId         String
  ownerOrgId         String
  status             ProviderRelationshipStatus @default(REQUESTED)
  requestedBy        String?
  providerRespondedAt DateTime?
  adminApprovedAt    DateTime?
  notes              String?
  complianceMarkets  String[]                   @default([])
  complianceProfile  Json?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  provider    SwapProvider                  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  ownerOrg    Organization                  @relation("OwnerOrganization", fields: [ownerOrgId], references: [id], onDelete: Restrict)
  documents   ProviderDocument[]
  settlementEntries ProviderSettlementEntry[]

  @@map("provider_relationships")
  @@index([providerId])
  @@index([ownerOrgId])
  @@index([status])
}

model ProviderDocument {
  id             String               @id @default(uuid())
  providerId     String?
  relationshipId String?
  ownerOrgId     String?
  type           ProviderDocumentType
  requirementCode String?
  category       String?
  name           String
  fileUrl        String
  cloudinaryPublicId String?
  issuer         String?
  documentNumber String?
  issueDate      DateTime?
  expiryDate     DateTime?
  coveredModels  String[]             @default([])
  coveredSites   String[]             @default([])
  version        String?
  metadata       Json?
  uploadedAt     DateTime             @default(now())
  uploadedBy     String?
  status         ProviderDocumentStatus @default(PENDING)
  reviewedBy     String?
  reviewedAt     DateTime?
  reviewNotes    String?
  rejectionReason String?

  provider     SwapProvider?         @relation(fields: [providerId], references: [id], onDelete: SetNull)
  relationship ProviderRelationship? @relation(fields: [relationshipId], references: [id], onDelete: SetNull)

  @@map("provider_documents")
  @@index([providerId])
  @@index([relationshipId])
  @@index([requirementCode])
  @@index([expiryDate])
  @@index([status])
}

model CompliancePolicy {
  id        String   @id @default(uuid())
  code      String   @unique
  data      Json
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("compliance_policies")
}

model ProviderSettlementEntry {
  id             String                  @id @default(uuid())
  relationshipId String?
  providerId     String
  ownerOrgId     String?
  stationId      String?
  sessionId      String?
  amount         Float
  providerFee    Float
  platformFee    Float
  adjustment     Float                   @default(0)
  net            Float
  currency       String                  @default("USD")
  status         ProviderSettlementStatus @default(PENDING)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  provider     SwapProvider          @relation(fields: [providerId], references: [id], onDelete: Cascade)
  relationship ProviderRelationship? @relation(fields: [relationshipId], references: [id], onDelete: SetNull)

  @@map("provider_settlement_entries")
  @@index([providerId])
  @@index([ownerOrgId])
  @@index([createdAt])
  @@index([status])
}

model MarketplaceContactEvent {
  id           String                       @id @default(uuid())
  actorId      String
  entityKind   MarketplaceContactEntityKind
  entityId     String
  eventType    MarketplaceContactEventType
  entityName   String?
  entityCity   String?
  entityRegion String?
  metadata     Json?
  createdAt    DateTime                     @default(now())

  @@map("marketplace_contact_events")
  @@index([actorId, createdAt])
  @@index([actorId, entityKind, entityId, createdAt])
}

model UserApplication {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation("UserApplication", fields: [userId], references: [id], onDelete: Cascade)
  
  // Application Details
  companyName     String?
  taxId           String?
  country         String
  region          String
  accounttype                 String     @default("COMPANY") // COMPANY, INDIVIDUAL
  tenantSubdomain      String?    @unique @map("tenant_subdomain")
  tenantTier           TenantTier @default(SHARED) @map("tenant_tier")
  tenantSchema         String?    @map("tenant_schema")
  tenantRoutingEnabled Boolean    @default(false) @map("tenant_routing_enabled")
  role            String   // STATION_OWNER, STATION_OPERATOR, etc.
  subscribedPackage String?
  
  // Documents (JSON array of document objects)
  documents       Json?    @default("[]") // [{type: 'ID', url: '...'}, {type: 'Certificate', url: '...'}]
  
  // Approval Workflow
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reviewedBy      String?
  reviewer        User?    @relation("ReviewedBy", fields: [reviewedBy], references: [id])
  reviewedAt      DateTime?
  rejectionReason String?
  adminNotes      String?
  
  // Metadata
  submittedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("user_applications")
}

model SubscriptionPlan {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  role        UserRole
  price       Float    @default(0)
  currency    String   @default("USD")
  billingCycle String  @default("MONTHLY") // MONTHLY, YEARLY
  isActive    Boolean  @default(true)
  isPublic    Boolean  @default(true)
  isPopular   Boolean  @default(false)
  
  // Relations
  features    PlanFeature[]
  permissions PlanPermission[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("subscription_plans")
}

model PlanFeature {
  id          String   @id @default(uuid())
  planId      String
  featureKey  String
  featureValue String
  description String?
  order       Int      @default(0)
  
  plan        SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("plan_features")
}

model PlanPermission {
  id          String   @id @default(uuid())
  planId      String
  resource    String
  action      String
  description String?
  
  plan        SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("plan_permissions")
}

model PermissionDefinition {
  id          String          @id @default(uuid())
  code        String          @unique
  label       String
  description String?
  scope       PermissionScope
  resource    String?
  action      String?
  isSystem    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  systemRoleTemplatePermissions SystemRoleTemplatePermission[]

  @@map("permission_definitions")
  @@index([scope])
}

model SystemRoleTemplate {
  id             String           @id @default(uuid())
  key            CanonicalRoleKey @unique
  label          String
  description    String?
  family         String
  scope          PermissionScope
  isPlatformRole Boolean          @default(false)
  customizable   Boolean          @default(false)
  version        Int              @default(1)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  permissions SystemRoleTemplatePermission[]

  @@map("system_role_templates")
}

model SystemRoleTemplatePermission {
  id             String   @id @default(uuid())
  roleTemplateId String
  permissionId   String
  createdAt      DateTime @default(now())

  roleTemplate SystemRoleTemplate @relation(fields: [roleTemplateId], references: [id], onDelete: Cascade)
  permission   PermissionDefinition @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@map("system_role_template_permissions")
  @@unique([roleTemplateId, permissionId])
  @@index([permissionId])
}

model PlatformRoleAssignment {
  id         String            @id @default(uuid())
  userId     String
  roleKey    CanonicalRoleKey
  status     MembershipStatus  @default(ACTIVE)
  assignedBy String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@map("platform_role_assignments")
  @@unique([userId, roleKey])
  @@index([userId, status])
}

model Station {
  id        String  @id @default(uuid())
  name      String
  status    String  @default("ACTIVE")
  latitude  Float
  longitude Float
  address   String
  type        StationType @default(CHARGING)
  ownerId     String?
  operatorId  String?
  siteId      String?
  orgId       String?
  postalCode  String?
  zoneId      String?

  // New Fields
  rating      Float   @default(0)
  price       Float   @default(0)
  amenities   String  @default("[]") // JSON array
  images      String  @default("[]") // JSON array
  open247     Boolean @default(false)
  phone       String?
  bookingFee  Float   @default(0)

  // Relations
  zone         GeographicZone? @relation(fields: [zoneId], references: [id])

  // Relations
  owner        User?         @relation("StationOwner", fields: [ownerId], references: [id])
  operator     User?         @relation("StationOperator", fields: [operatorId], references: [id])
  site         Site?         @relation(fields: [siteId], references: [id])
  chargePoints ChargePoint[]
  incidents    Incident[]
  jobs         Job[]
  bookings     Booking[]
  attendantAssignments        AttendantAssignment[]
  attendantAssignmentRequests AttendantAssignmentRequest[]
  stationTeamAssignments      StationTeamAssignment[]
  batteryPacks                BatteryPack[]
  energyDerProfiles           EnergyDerProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("stations")
}

model ChargePoint {
  id              String  @id @default(uuid())
  stationId       String
  ocppId          String  @unique
  status          String  @default("AVAILABLE")
  ocppVersion     String  @default("1.6")
  model           String?
  vendor          String?
  firmwareVersion String?
  bootNotificationAt      DateTime? @map("boot_notification_at")
  bootNotificationPayload Json?     @map("boot_notification_payload")
  identityConfirmedAt     DateTime? @map("identity_confirmed_at")
  firmwareUpdateStatus    String?   @map("firmware_update_status")
  firmwareUpdateRequestId Int?      @map("firmware_update_request_id")
  firmwareStatusUpdatedAt DateTime? @map("firmware_status_updated_at")
  type            String  @default("CCS2")
  power           Float   @default(50.0)
  lastHeartbeat   DateTime?

  // Auth for OCPP Gateway
  clientSecretHash String?
  clientSecretSalt String?
  allowedInsecure  Boolean @default(false)
  smartChargingEnabled Boolean @default(false)

  station  Station   @relation(fields: [stationId], references: [id])
  sessions Session[]
  statusHistory ChargePointStatusHistory[]
  firmwareEvents FirmwareUpdateEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("charge_points")
}

model Session {
  id          String  @id @default(uuid())
  stationId   String
  connectorId Int
  ocppTxId    String? @unique
  ocppId      String
  idTag       String?
  userId      String?
  vehicleId   String?

  startTime   DateTime
  endTime     DateTime?
  meterStart  Float     @default(0)
  meterStop   Float     @default(0)
  totalEnergy Float     @default(0)
  amount      Float     @default(0) // Revenue in USD
  status      String    @default("ACTIVE")

  chargePoint ChargePoint @relation(fields: [ocppId], references: [ocppId])
  user        User?       @relation(fields: [userId], references: [id])
  vehicle     Vehicle?    @relation(fields: [vehicleId], references: [id])
  receiptTransactions ChargingReceiptTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sessions")
}

model EnergyLoadGroup {
  id                      String                @id @default(uuid())
  tenantId                String                @map("tenant_id")
  stationId               String                @map("station_id")
  name                    String
  description             String?
  controlMode             EnergyControlMode     @default(OBSERVE_ONLY) @map("control_mode")
  allocationMethod        EnergyAllocationMethod @default(EQUAL) @map("allocation_method")
  meterSource             String?               @map("meter_source")
  meterPlacement          EnergyMeterPlacement  @default(MAIN) @map("meter_placement")
  siteLimitAmpsPhase1     Int                   @default(0) @map("site_limit_amps_phase_1")
  siteLimitAmpsPhase2     Int                   @default(0) @map("site_limit_amps_phase_2")
