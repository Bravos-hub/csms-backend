
PORT=3000
NODE_ENV=development
API_RATE_LIMIT_TTL_MS=60000
API_RATE_LIMIT_LIMIT=120
API_BODY_LIMIT=1mb
API_REQUEST_TIMEOUT_MS=30000
API_HEADERS_TIMEOUT_MS=35000
API_KEEP_ALIVE_TIMEOUT_MS=5000
API_READINESS_REQUIRE_KAFKA=false
API_READINESS_REQUIRE_REDIS=false
API_KAFKA_REQUIRED_ON_STARTUP=true
REQUEST_LOGGING_ENABLED=true
REQUEST_LOGGING_SAMPLE_RATE=1

# Submail API (China email + SMS, and non-China fallback)
SUBMAIL_MAIL_APPID=
SUBMAIL_MAIL_APPKEY=
SUBMAIL_MAIL_FROM="EVzone Charging <noreply@evzonecharging.com>"
SUBMAIL_SMS_APPID=
SUBMAIL_SMS_APPKEY=

# Twilio SMS (Global SMS primary except Africa)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Twilio SendGrid (Email primary outside China)
TWILIO_SENDGRID_API_KEY=
TWILIO_SENDGRID_FROM=EVzone Charging <noreply@evzonecharging.com>

# Payment provider health probe
PAYMENT_HEALTHCHECK_URL=
PAYMENT_HEALTHCHECK_BEARER_TOKEN=
PAYMENT_HEALTHCHECK_TIMEOUT_MS=5000

# Africa's Talking SMS (Africa SMS primary)
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_FROM=

# Database
DATABASE_URL=postgresql://user:password@db-host:5432/evzone
DATABASE_TLS=true
DATABASE_TLS_REJECT_UNAUTHORIZED=true
# DATABASE_TLS_CA_PATH=/app/certs/db-ca.pem


# Tenant routing
TENANT_PLATFORM_HOSTS=portal.evzonecharging.com
TENANT_DEDICATED_DB_URLS_JSON={}
TENANT_HEADER_FALLBACK_DEV=true
TENANT_CLIENT_CACHE_MAX=200
# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_EVENTS_ENABLED=true
KAFKA_EVENT_CLIENT_ID=evzone-backend-api
KAFKA_EVENT_GROUP_ID=evzone-backend-api-events
KAFKA_CLIENT_ID=evzone-worker
KAFKA_SSL=false
KAFKA_SSL_REJECT_UNAUTHORIZED=true

# Tenant routing
TENANT_PLATFORM_HOSTS=portal.evzonecharging.com
TENANT_DEDICATED_DB_URLS_JSON={}
TENANT_HEADER_FALLBACK_DEV=true
TENANT_CLIENT_CACHE_MAX=200
# Kafka_SSL_CA_PATH=/app/certs/kafka-ca.pem

# Tenant routing
TENANT_PLATFORM_HOSTS=portal.evzonecharging.com
TENANT_DEDICATED_DB_URLS_JSON={}
TENANT_HEADER_FALLBACK_DEV=true
TENANT_CLIENT_CACHE_MAX=200
# Kafka_SASL_MECHANISM=plain

# Tenant routing
TENANT_PLATFORM_HOSTS=portal.evzonecharging.com
TENANT_DEDICATED_DB_URLS_JSON={}
TENANT_HEADER_FALLBACK_DEV=true
TENANT_CLIENT_CACHE_MAX=200
# Kafka_SASL_USERNAME=username

# Tenant routing
TENANT_PLATFORM_HOSTS=portal.evzonecharging.com
TENANT_DEDICATED_DB_URLS_JSON={}
TENANT_HEADER_FALLBACK_DEV=true
TENANT_CLIENT_CACHE_MAX=200
# Kafka_SASL_PASSWORD=password
KAFKA_TOPIC_COMMAND_REQUESTS=cpms.command.requests
KAFKA_TOPIC_COMMAND_EVENTS=ocpp.command.events
KAFKA_TOPIC_COMMAND_DEAD_LETTERS=cpms.command.dead_letters
KAFKA_TOPIC_STATION_EVENTS=ocpp.station.events
KAFKA_TOPIC_SESSION_EVENTS=ocpp.session.events
KAFKA_TOPIC_AUDIT_EVENTS=cpms.audit.events
KAFKA_TOPIC_LEGACY_STATION_EVENTS=ocpp.events

# Redis
REDIS_URL=redis://redis:6379
REDIS_TLS=false
REDIS_TLS_REJECT_UNAUTHORIZED=true
# REDIS_TLS_CA_PATH=/app/certs/redis-ca.pem

# Worker
WORKER_PORT=3010
WORKER_COMMAND_EVENTS_ENABLED=true
WORKER_COMMAND_EVENT_GROUP_ID=evzone-worker-command-events
OUTBOX_ENABLED=true
OUTBOX_INTERVAL_MS=2000
OUTBOX_BATCH_SIZE=50
OUTBOX_LOCK_TTL_MS=60000
OUTBOX_RETRY_BACKOFF_MS=5000
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_READY_MAX_BACKLOG=10000
OUTBOX_READY_MAX_OLDEST_AGE_SEC=600
OUTBOX_CIRCUIT_BREAKER_ENABLED=true
OUTBOX_CIRCUIT_OPEN_MS=15000
OUTBOX_CIRCUIT_FAILURE_THRESHOLD=5
WORKER_READY_MAX_CONSUMER_LAG=1000
COMMAND_HISTORY_CLEANUP_ENABLED=true
COMMAND_HISTORY_CLEANUP_INTERVAL_MS=3600000
COMMAND_HISTORY_RETENTION_DAYS=30
COMMAND_HISTORY_CLEANUP_BATCH_SIZE=1000
WORKER_AUDIT_ENABLED=true

# OCPP provisioning response
OCPP_PUBLIC_WS_BASE_URL=wss://ocpp.evzonecharging.com
FEATURE_OCPP_FIRMWARE_COMMANDS_ENABLED=false
FEATURE_OCPP_FIRMWARE_STATUS_PERSIST_ENABLED=false
ENERGY_SIMULATION_ENABLED=false
ATTENDANT_SYNC_ENABLED=false

# Geography reference providers
GEOGRAPHY_REFERENCE_CACHE_TTL_MINUTES=720
GEOGRAPHY_REFERENCE_REQUEST_TIMEOUT_MS=10000
GEOGRAPHY_REST_COUNTRIES_BASE_URL=https://restcountries.com/v3.1
GEOGRAPHY_CSC_BASE_URL=https://api.countrystatecity.in/v1
GEOGRAPHY_IPAPI_BASE_URL=https://ipapi.co
GEOGRAPHY_IPAPI_KEY=
GEOGRAPHY_OPENCAGE_BASE_URL=https://api.opencagedata.com/geocode/v1
GEOGRAPHY_OPENCAGE_API_KEY=

# Free CountryStateCity API key (required for states/cities endpoints - set per environment)
CSC_API_KEY=

