# EVZONE backend runtime template
# `.env` is the only active runtime file.
# Keep real secrets in `.env` only.

# Runtime
NODE_ENV=development
PORT=3000
APP_NAME=EVzone
CORS_ORIGINS=http://localhost:5173,https://portal.evzonecharging.com
FRONTEND_URL=http://localhost:5173

# API behavior
API_RATE_LIMIT_TTL_MS=60000
API_RATE_LIMIT_LIMIT=120
API_BODY_LIMIT=1mb
API_REQUEST_TIMEOUT_MS=30000
API_HEADERS_TIMEOUT_MS=35000
API_KEEP_ALIVE_TIMEOUT_MS=5000
REQUEST_LOGGING_ENABLED=true
REQUEST_LOGGING_SAMPLE_RATE=1
API_READINESS_REQUIRE_KAFKA=false
API_READINESS_REQUIRE_REDIS=false
API_KAFKA_REQUIRED_ON_STARTUP=true

# Authentication
JWT_SECRET=TODO_SET_JWT_SECRET
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_SERVICE_SECRET=TODO_SET_JWT_SERVICE_SECRET
JWT_SERVICE_ISSUER=evzone-backend
JWT_SERVICE_AUDIENCE=evzone-services
JWT_SERVICE_EXPIRY=1y
# Optional: leave empty to reuse JWT_SECRET for 2FA secret encryption
AUTH_2FA_ENCRYPTION_KEY=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/evzone
DATABASE_TLS=false
DATABASE_TLS_REJECT_UNAUTHORIZED=true
DATABASE_TLS_CA_PATH=
PG_SSL_REJECT_UNAUTHORIZED=true

# Redis
REDIS_URL=redis://localhost:6379
REDIS_TLS=false
REDIS_TLS_REJECT_UNAUTHORIZED=true
REDIS_TLS_CA_PATH=

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_EVENTS_ENABLED=true
KAFKA_EVENT_CLIENT_ID=evzone-backend-api
KAFKA_EVENT_GROUP_ID=evzone-backend-api-events
KAFKA_CLIENT_ID=evzone-worker
KAFKA_SSL=false
KAFKA_SSL_REJECT_UNAUTHORIZED=true
KAFKA_SSL_CA_PATH=
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_CONNECTION_TIMEOUT_MS=30000
KAFKA_REQUEST_TIMEOUT_MS=30000
KAFKA_TOPIC_COMMAND_REQUESTS=cpms.command.requests
KAFKA_TOPIC_COMMAND_REQUESTS_NODE_PREFIX=cpms.command.requests.node
KAFKA_TOPIC_SESSION_CONTROL_NODE_PREFIX=ocpp.session.control.node
KAFKA_TOPIC_COMMAND_EVENTS=ocpp.command.events
KAFKA_TOPIC_COMMAND_DEAD_LETTERS=cpms.command.dead_letters
KAFKA_TOPIC_STATION_EVENTS=ocpp.station.events
KAFKA_TOPIC_SESSION_EVENTS=ocpp.session.events
KAFKA_TOPIC_AUDIT_EVENTS=cpms.audit.events
KAFKA_TOPIC_LEGACY_STATION_EVENTS=ocpp.events

# Worker
WORKER_PORT=3010
WORKER_COMMAND_EVENTS_ENABLED=true
WORKER_COMMAND_EVENT_GROUP_ID=evzone-worker-command-events
WORKER_AUDIT_ENABLED=true
WORKER_READY_MAX_CONSUMER_LAG=1000
OUTBOX_ENABLED=true
OUTBOX_INTERVAL_MS=2000
OUTBOX_BATCH_SIZE=50
OUTBOX_LOCK_TTL_MS=60000
OUTBOX_RETRY_BACKOFF_MS=5000
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_READY_MAX_BACKLOG=10000
OUTBOX_READY_MAX_OLDEST_AGE_SEC=600
OUTBOX_CIRCUIT_BREAKER_ENABLED=true
OUTBOX_CIRCUIT_FAILURE_THRESHOLD=5
OUTBOX_CIRCUIT_OPEN_MS=15000
COMMAND_HISTORY_CLEANUP_ENABLED=true
COMMAND_HISTORY_CLEANUP_INTERVAL_MS=3600000
COMMAND_HISTORY_RETENTION_DAYS=30
COMMAND_HISTORY_CLEANUP_BATCH_SIZE=1000

# Messaging providers
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_SENDGRID_API_KEY=
TWILIO_SENDGRID_FROM=EVzone Charging <noreply@evzonecharging.com>
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_FROM=
SUBMAIL_MAIL_APPID=
SUBMAIL_MAIL_APPKEY=
SUBMAIL_MAIL_FROM=EVzone Charging <noreply@evzonecharging.com>
SUBMAIL_SMS_APPID=
SUBMAIL_SMS_APPKEY=

# Media storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Geography
GEOGRAPHY_REFERENCE_CACHE_TTL_MINUTES=720
GEOGRAPHY_REFERENCE_REQUEST_TIMEOUT_MS=10000
GEOGRAPHY_REST_COUNTRIES_BASE_URL=https://restcountries.com/v3.1
GEOGRAPHY_CSC_BASE_URL=https://api.countrystatecity.in/v1
GEOGRAPHY_CSC_API_KEY=

# OCPP
OCPP_PUBLIC_WS_BASE_URL=wss://ocpp.evzonecharging.com
OCPP_GATEWAY_URL=http://localhost:3003
OCPP_ENABLE_NOAUTH_BOOTSTRAP=false
OCPP_NOAUTH_BOOTSTRAP_DEFAULT_MINUTES=30
OCPP_NOAUTH_BOOTSTRAP_MAX_MINUTES=120
OCPP_IDENTITY_PREFIX=chargers

# Optional feature flags and partner defaults
ATTENDANT_SYNC_ENABLED=false
OCPI_COUNTRY_CODE=US
OCPI_PARTY_ID=EVZ
OCPI_COMMAND_CALLBACKS_ENABLED=true
OCPI_COMMAND_CALLBACK_TIMEOUT_MS=5000
PAYMENT_PROVIDER=

# Future or currently unused placeholders
# DOCUSIGN_ENABLED=false
# DOCUSIGN_CLIENT_ID=
# DOCUSIGN_USER_ID=
# DOCUSIGN_PRIVATE_KEY=
# REDIS_HOST=localhost
# REDIS_PORT=6379
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=evzone
# CSC_API_KEY=
# CSC_API_BASE_URL=https://api.countrystatecity.in/v1
